# symPO 환경변수 — 팀원 실험용 템플릿
# ────────────────────────────────────────────────
# 이 파일을 `.env`로 복사한 뒤 본인 값으로 채우세요.
#   cp .env.example .env
#
# ⚠️  API 키와 토큰은 절대 Git에 커밋하지 마세요 (.gitignore 확인).
# ────────────────────────────────────────────────

# ── 1) LLM 백엔드 선택 ─────────────────────────────
# mock        : 키 불필요, 결정적 응답 (오프라인/CI용)
# gemini      : Google Gemini API
# openai      : OpenAI GPT API
# anthropic   : Claude API
# ollama      : 로컬 Ollama 서버
# gemma4      : 로컬 Gemma 4 모델 (transformers + GPU 필요)
# gemma4-api  : OpenAI 호환 Gemma 4 원격 서버
# qwen-api    : OpenAI 호환 Qwen 원격 서버
# llama4      : 로컬 Llama 4 모델 (transformers + GPU 필요)
LLM_BACKEND=mock

# Gemini (LLM_BACKEND=gemini 선택 시)
GOOGLE_API_KEY=

# OpenAI (LLM_BACKEND=openai 선택 시)
# OPENAI_API_KEY=

# Anthropic (LLM_BACKEND=anthropic 선택 시)
# ANTHROPIC_API_KEY=

# Ollama (LLM_BACKEND=ollama 선택 시)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# Gemma4 원격 API (LLM_BACKEND=gemma4-api 선택 시)
# GEMMA4_API_URL=https://xxxxx.ngrok-free.app
# GEMMA4_API_MODEL=google/gemma-4-E4B-it
# GEMMA4_API_KEY=

# Qwen 원격 API (LLM_BACKEND=qwen-api 선택 시)
# QWEN_API_URL=https://your-qwen-endpoint
# QWEN_API_MODEL=Qwen/Qwen2.5-7B-Instruct
# QWEN_API_KEY=
# QWEN_MAX_CONTEXT=16384
# QWEN_ENABLE_THINKING=false

# ── 2) 실험 재현성 설정 ────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
MAX_DEBATE_ROUNDS=3
OUTPUT_DIR=./generated

# 팀 실험 시 결과 파일 충돌 방지용 식별자.
# 미지정이면 $USER 또는 "anon"이 쓰입니다.
# 예: RUNNER_ID=kim  →  summary_gemini_kim_20260419_120000.csv
# RUNNER_ID=

# ── 3) LangSmith 트레이싱 (선택) ───────────────────
# 활성화 시 모든 에이전트·LLM 호출이 단일 Trace 트리로 기록됩니다.
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=sympo

# ── 4) HuggingFace (임베딩 다운로드용, 선택) ───────
# HF_TOKEN=
